0], color='#1DB954', edgecolor='white', alpha=0.85)\n","    axes[0].set_title('Top 15 artistas por streams totales', fontsize=11)\n","    axes[0].set_xlabel('Streams totales')\n","    axes[0].xaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'{x/1e9:.1f}B'))\n","\n","# Mediana de streams por año\n","if 'Release Year' in df_spotify.columns:\n","    yr_sp = df_spotify[df_spotify['Release Year'].between(2010, 2024)]\n","    yr_med = yr_sp.groupby('Release Year')[stream_col].median()\n","    yr_med.plot(ax=axes[1], marker='o', color='#378ADD', linewidth=2)\n","    axes[1].fill_between(yr_med.index, yr_med.values, alpha=0.15, color='#378ADD')\n","    axes[1].set_title('Mediana de streams por año de lanzamiento', fontsize=11)\n","    axes[1].set_xlabel('Año')\n","    axes[1].yaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'{x/1e9:.1f}B'))\n","\n","plt.suptitle('df_spotify — Análisis del target (Spotify Streams)', fontsize=13, fontweight='bold')\n","plt.tight_layout()\n","plt.show()\n","\n","print('\\nTop 10 canciones por streams:')\n","top10 = df_spotify.nlargest(10, stream_col)[['Track', 'Artist', stream_col]].copy()\n","top10[stream_col] = top10[stream_col].map(lambda x: f'{x/1e9:.2f}B')\n","display(top10.reset_index(drop=True))"],"id":"BT5FSgD3vKQS"},{"cell_type":"markdown","metadata":{"id":"5s39bAtNvKQS"},"source":["## 4.10 Resumen de hallazgos — df_spotify\n","\n","| Aspecto | Detalle |\n","|---|---|\n","| **Tamaño** | aproximadamente 4.600 filas × 29 columnas |\n","| **Datos sucios** |  15 columnas numéricas almacenadas como strings con comas → convertidas en paso 4.2 |\n","| **Nulos** | Plataformas secundarias (Pandora, Soundcloud, TIDAL) con nulos esperables |\n","| **Duplicados** | Verificados y tratados |\n","| **Outliers** | Extremos en streams; la escala log los normaliza significativamente |\n","| **Multicolinealidad** | Plataformas altamente correlacionadas entre sí → cuidado en el modelo |\n","| **Distribución** | Target fuertemente log-normal |\n","| **Problemática** | **Regresión:** predecir streams de Spotify desde métricas de otras plataformas |\n","| **Desafío** | Conversión de tipos + multicolinealidad + nulos en plataformas secundarias |"],"id":"5s39bAtNvKQS"},{"cell_type":"markdown","metadata":{"id":"ooSP3W71vKQS"},"source":["---\n","# Diagnóstico Comparativo y Selección de Problema\n","\n","## Diagnóstico comparativo de los 4 datasets\n","\n","| Criterio | df_bank | df_heart | df_game | df_spotify |\n","|---|---|---|---|---|\n","| **Filas** | 10.000 | ~1.000 | 50.000 | ~4.600 |\n","| **Columnas** | 15 útiles | 21 | 34 útiles | 29 |\n","| **Nulos** |  Ninguno |  Pocos | Moderados |  Plataformas sec. |\n","| **Duplicados** |  Ninguno | Verificar | Verificar | Verificar |\n","| **Tipos de datos** |  Correctos |  Correctos |  Correctos |  Conversión crítica |\n","| **Outliers** | Moderados | Clínicos reales | Extremos | Extremos (log-normal) |\n","| **Balance** |  Desbalanceado |  Balanceado | N/A | N/A |\n","| **Tipo de problema** | Clasificación | Clasificación | Regresión | Regresión |\n","| **Dominio** | Banca | Salud | Entretenimiento | Música |\n","| **Potencial ML** | 5 estrellas |  4 estrellas | 4 estrellas | 4 estrellas |"],"id":"ooSP3W71vKQS"},{"cell_type":"code","execution_count":110,"metadata":{"id":"acXLvZNDvKQT","executionInfo":{"status":"ok","timestamp":1780962884528,"user_tz":240,"elapsed":616,"user":{"displayName":"Marco Brante","userId":"13374846059171518875"}},"colab":{"base_uri":"https://localhost:8080/","height":558},"outputId":"8476bbc1-c4b3-447e-bdb9-75d9ce7a68ac"},"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1650x550 with 3 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["# Visualización comparativa\n","datasets_comp = {\n","    'df_bank\\n(Bank Churn)': {'filas': 10000, 'columnas': 15, 'nulos_pct': 0},\n","    'df_heart\\n(Heart Disease)': {'filas': 1000, 'columnas': 21, 'nulos_pct': 5},\n","    'df_game\\n(Video Games)': {'filas': 50000, 'columnas': 34, 'nulos_pct': 15},\n","    'df_spotify\\n(Spotify 2024)': {'filas': 4600, 'columnas': 29, 'nulos_pct': 35},\n","}\n","\n","nombres = list(datasets_comp.keys())\n","filas   = [v['filas'] for v in datasets_comp.values()]\n","cols_n  = [v['columnas'] for v in datasets_comp.values()]\n","nulos   = [v['nulos_pct'] for v in datasets_comp.values()]\n","colors_ds = ['#378ADD', '#5DCAA5', '#7F77DD', '#1DB954']\n","\n","fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n","\n","axes[0].bar(nombres, filas, color=colors_ds, edgecolor='white')\n","axes[0].set_title('N° de filas', fontsize=11)\n","for i, v in enumerate(filas): axes[0].text(i, v + 200, f'{v:,}', ha='center', fontsize=8)\n","\n","axes[1].bar(nombres, cols_n, color=colors_ds, edgecolor='white')\n","axes[1].set_title('N° de columnas', fontsize=11)\n","for i, v in enumerate(cols_n): axes[1].text(i, v + 0.3, str(v), ha='center', fontsize=9)\n","\n","axes[2].bar(nombres, nulos, color=colors_ds, edgecolor='white')\n","axes[2].axhline(y=30, color='red', linestyle='--', alpha=0.5, label='30% umbral')\n","axes[2].set_title('% promedio de nulos', fontsize=11)\n","axes[2].legend()\n","for i, v in enumerate(nulos): axes[2].text(i, v + 0.5, f'{v}%', ha='center', fontsize=9)\n","\n","plt.suptitle('Comparativa de los 4 datasets', fontsize=13, fontweight='bold')\n","plt.tight_layout()\n","plt.show()"],"id":"acXLvZNDvKQT"},{"cell_type":"markdown","metadata":{"id":"TkGdKYbJvKQT"},"source":["## Dataset seleccionado y justificación\n","\n","### Dataset elegido: **Bank Customer Churn** (`df_bank`)\n","### Problemática: **Clasificación binaria — Predicción de abandono de clientes**\n","\n","---\n","\n","### ¿Por qué este dataset?\n","\n","#### 1. Relevancia del problema de negocio\n","El **churn bancario** es uno de los problemas más críticos en la industria financiera.  \n","Adquirir un cliente nuevo cuesta entre **5 y 7 veces más** que retener uno existente.  \n","Un modelo predictivo permite actuar de forma proactiva sobre los clientes en riesgo.\n","\n","#### 2. Calidad y diversidad de features\n","Combina variables demográficas, financieras, de comportamiento y de satisfacción → rich feature set.\n","\n","#### 3. Desafíos técnicos equilibrados\n","\n","| Desafío | Nivel | Tratamiento |\n","|---|---|---|\n","| Desbalance de clases (casi un 20% churn) |  Medio | SMOTE o `class_weight='balanced'` |\n","| Variables categóricas |  Manejable | One-Hot o Label Encoding |\n","| Balance bimodal (muchos $0) |  Interesante | Análisis diferenciado |\n","| Sin nulos ni duplicados |  Facilita | No requiere imputación |\n","\n","#### 4. Modelos candidatos para la Parte II\n","\n","| Modelo | Rol |\n","|---|---|\n","| Logistic Regression | Baseline interpretable |\n","| Random Forest | Modelo principal |\n","| XGBoost / Gradient Boosting | Modelo avanzado |\n","\n","**Métrica principal:** F1-Score (por desbalance) + AUC-ROC\n","\n","#### 5. Aplicabilidad real\n","Directamente aplicable al contexto bancario (BCI, Banco de Chile), reforzando la relevancia profesional del proyecto.\n","\n","---\n","\n","### Razones de descarte de los otros datasets\n","\n","| Dataset | Razón de no selección |\n","|---|---|\n","| df_heart | Tamaño pequeño (cerca de 1.000 filas); menor volumen para generalización del modelo |\n","| df_game | Asimetría extrema del target + alta cardinalidad dificultan el modelado de regresión |\n","| df_spotify | Multicolinealidad extrema entre plataformas + conversión de tipos compleja |"],"id":"TkGdKYbJvKQT"}]}
